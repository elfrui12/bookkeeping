      <button class="btn btn-secondary btn-sm" onclick="exportData()">📤 导出 JSON</button>
    </div>
    <button class="btn btn-danger btn-sm" onclick="confirmClearData()">🗑️ 清除所有数据</button>
    <p style="font-size:11px;color:var(--text-muted);margin-top:4px">此操作不可撤销，建议先导出备份</p>
  </div>
</div>

<!-- 日常账单弹窗 -->
<div class="modal-overlay" id="dailyModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="dailyModalTitle">记一笔</h3>
      <button class="modal-close" onclick="closeDailyModal()">×</button>
    </div>
    <form id="dailyForm" onsubmit="saveDailyTx(event)">
      <input type="hidden" id="dtxId">
      <div class="form-group">
        <div class="type-toggle">
          <button type="button" id="dtxExpenseBtn" class="active-expense" onclick="setDTxType('expense')">🔴 支出</button>
          <button type="button" id="dtxIncomeBtn" onclick="setDTxType('income')">🟢 收入</button>
        </div>
        <input type="hidden" id="dtxType" value="expense">
      </div>
      <div class="form-group"><label>金额 (¥)</label><input type="number" class="form-input" id="dtxAmount" placeholder="0.00" min="0.01" step="0.01" required></div>
      <div class="form-row">
        <div class="form-group"><label>日期</label><input type="date" class="form-input" id="dtxDate" required></div>
        <div class="form-group"><label>一级分类</label><select class="form-select" id="dtxPrimaryCat" onchange="onPrimaryCatChange()" required></select></div>
      </div>
      <div class="form-group"><label>二级分类（可选）</label><select class="form-select" id="dtxSecondaryCat"><option value="">-- 不选 --</option></select></div>
      <div class="form-group"><label>备注</label><input type="text" class="form-input" id="dtxNote" placeholder="备注（可选）" maxlength="100"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:18px">
        <button type="button" class="btn btn-danger btn-sm" id="dtxDeleteBtn" style="display:none" onclick="deleteCurrentDTx()">🗑️ 删除</button>
        <div style="flex:1;display:flex;justify-content:flex-end;gap:8px">
          <button type="button" class="btn btn-secondary" onclick="closeDailyModal()">取消</button>
          <button type="submit" class="btn btn-primary" id="dtxSubmitBtn">保存</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- 出借弹窗 -->
<div class="modal-overlay" id="lendingModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="lendingModalTitle">记出借</h3>
      <button class="modal-close" onclick="closeLendingModal()">×</button>
    </div>
    <form id="lendingForm" onsubmit="saveLending(event)">
      <input type="hidden" id="lendId">
