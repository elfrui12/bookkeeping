        <div class="form-group"><label>借款人</label><input type="text" class="form-input" id="lendBorrower" placeholder="姓名" required></div>
        <div class="form-group"><label>金额 (¥)</label><input type="number" class="form-input" id="lendAmount" placeholder="0.00" min="0.01" step="0.01" required></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>借出日期</label><input type="date" class="form-input" id="lendDate" required></div>
        <div class="form-group"><label>预计归还</label><input type="date" class="form-input" id="lendExpected"></div>
      </div>
